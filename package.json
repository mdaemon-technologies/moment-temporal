{
  "name": "@mdaemon/moment-temporal",
  "type": "module",
  "version": "1.0.0",
  "description": "Drop-in moment replacement backed by the Temporal API, with graceful fallback to moment when Temporal is unavailable.",
  "main": "dist/moment-temporal.umd.js",
  "module": "dist/moment-temporal.mjs",
  "browser": "dist/moment-temporal.umd.js",
  "common": "dist/moment-temporal.cjs",
  "typings": "dist/moment-temporal.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "jest",
    "watch": "jest --watchAll",
    "pub": "npm run build && npm run test && npm publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mdaemon-technologies/moment-temporal.git"
  },
  "bugs": {
    "url": "https://github.com/mdaemon-technologies/moment-temporal/issues"
  },
  "keywords": [
    "moment",
    "temporal",
    "date",
    "time",
    "timezone",
    "drop-in",
    "polyfill",
    "typescript",
    "moment-timezone"
  ],
  "author": {
    "name": "MDaemon Technologies, Ltd.",
    "email": "jonathan.ehman@mdaemon.com",
    "url": "https://www.mdaemon.com"
  },
  "license": "LGPL-2.1",
  "homepage": "https://github.com/mdaemon-technologies/moment-temporal#readme",
  "dependencies": {
    "moment": "^2.30.1",
    "moment-timezone": "^0.5.45"
  },
  "devDependencies": {
    "@js-temporal/polyfill": "^0.4.4",
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "rollup": "^4.40.0",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3"
  },
  "files": [
    "dist"
  ]
}
